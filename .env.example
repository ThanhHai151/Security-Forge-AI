# Copy to .env and fill in. Secrets never go in committed files.

# Which model backend the agent loop uses: "offline" (no key, heuristic), "anthropic",
# or "openrouter" (OpenAI-compatible; any model OpenRouter exposes).
SECFORGE_MODEL_BACKEND=offline

# Required only when SECFORGE_MODEL_BACKEND=anthropic. Leave blank for offline demos.
ANTHROPIC_API_KEY=

# Required only when SECFORGE_MODEL_BACKEND=openrouter. Get one without copy-paste via
# `python -m ai_framework.openrouter_login` (OAuth PKCE), or paste an existing key here.
OPENROUTER_API_KEY=
# Optional: which OpenRouter model to call (defaults to openai/gpt-4o-mini).
OPENROUTER_MODEL=

# ── Local AI proxies (the AI Agent console) ──────────────────────────────────
# 9router and Antigravity-Manager are OpenAI-compatible relays you run separately;
# they own the AI accounts/OAuth. SecForge only needs their endpoint (and a key if
# you set one in their dashboard). Defaults match each tool's standard port.
#   9router:     https://github.com/decolua/9router          (dashboard :20128)
#   antigravity: https://github.com/lbjlaq/Antigravity-Manager (app :8045)
NINEROUTER_BASE_URL=http://localhost:20128/v1
NINEROUTER_API_KEY=
ANTIGRAVITY_BASE_URL=http://localhost:8045/v1
ANTIGRAVITY_API_KEY=

# Backend HTTP API bind address. Port convention: frontend dev port (61020) + 1.
SECFORGE_API_HOST=127.0.0.1
SECFORGE_API_PORT=61021

# Required when binding the API beyond loopback. The frontend/API client must send this as
# `Authorization: Bearer <token>`. Do not expose the local control plane without it.
SECFORGE_API_TOKEN=

# Encryption key for local provider credentials. Set this from an OS keyring/secret manager in
# managed deployments. When unset, SecForge generates a mode-0600 local key beside ai_accounts.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECFORGE_MASTER_KEY=

# Autonomous runs require an active, validated Rules of Engagement by default. Set to 0 only in
# offline unit tests or deliberately isolated development environments.
SECFORGE_REQUIRE_ROE=1

# Host execution of external tools and Playwright is disabled by default. Supply a sandboxed
# ToolContext.runner / renderer instead. These emergency development overrides are unsafe.
SECFORGE_ALLOW_HOST_TOOLS=0
SECFORGE_ALLOW_HOST_BROWSER=0

# Append-only, hash-chained, redacted evidence ledger location.
SECFORGE_EVIDENCE=evidence_ledger.jsonl

# Gemini CLI OAuth sign-in (optional). Google flags OAuth client id/secret as secrets, so they
# are NOT shipped in the repo — paste the Gemini CLI client credentials here to enable that flow.
SECFORGE_GEMINI_CLIENT_ID=
SECFORGE_GEMINI_CLIENT_SECRET=
